APP_NAME=One Stop Resume Engine
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENABLE_TRANSFORMER_EMBEDDINGS=false
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
