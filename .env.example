GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=
GMAIL_MAX_ATTACHMENT_SIZE_MB=2
GMAIL_MAX_ATTACHMENTS_PER_IMPORT=5
RESUME_MAX_TEXT_CHARACTERS=25000
RESUME_PDF_MAX_PAGES=10
LINKEDIN_CLIENT_ID=
